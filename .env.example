# URL base da API incluindo /api/v1 (sem barra final). Usada pelo BFF (Route Handlers).
# Ex.: API na porta 3000 e Next noutra porta.
API_URL=http://localhost:3000/api/v1

# Fallback legado (browser nao deve chamar a API directamente apos migracao BFF).
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Timeout por pedido HTTP (ms)
API_TIMEOUT_MS=10000

# Forcar Secure nos cookies de sessao (ex.: dev com HTTPS)
# AUTH_COOKIE_SECURE=true

# Na API Gescom: CORS_ORIGINS deve listar a origem exacta desta app (ex.: http://localhost:3001).
